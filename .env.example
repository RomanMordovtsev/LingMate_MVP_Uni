# Какой LLM-провайдер использовать. Варианты:
#   gemini  — облачный Gemini API (нужен GEMINI_API_KEY)
#   ollama  — локальная модель через Ollama (нужно установить ollama и pull модели)
#   auto    — пробуем Ollama, при недоступности — Gemini
LLM_PROVIDER=auto

# --- Gemini -----------------------------------------------------------------
GEMINI_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=true

# --- Ollama -----------------------------------------------------------------
# Установка:
#   1. Скачать Ollama: https://ollama.com/download
#   2. Запустить ollama serve (или просто открыть приложение — оно стартует в фоне)
#   3. ollama pull qwen2.5:7b-instruct   # ~4.4 GB, лучшая 7B-модель для испанского
#      или ollama pull llama3.1:8b-instruct-q4_K_M  # ~4.7 GB, хороший дефолт
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=120
