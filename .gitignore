# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.sqlite3

# Env
.env
.venv/
venv/

# Runtime user state — per-user JSON created by storage.py at startup.
# The data/ directory itself stays in git (README + .gitkeep) so the
# folder exists after a clone; only the user-specific files are ignored.
data/*.json
!data/.gitkeep

